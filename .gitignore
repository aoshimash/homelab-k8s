*.agekey

# Generated Talos configs (contain secrets, regenerated from talsecret.sops.yaml)
# - Node configs (*.yaml): machine configuration for each node
# - talosconfig: client credentials for talosctl (contains private key)
infra/talos/clusterconfig/

# Generated talhelper schema (can be regenerated with `talhelper genschema`)
infra/talos/talconfig.json

# Claude Code (local settings are per-user)
.claude/settings.local.json

# macOS
.DS_Store

# Kubernetes / kubectl
.kube/
kubeconfig*
secrets/
*.secret.yaml
# SOPS-encrypted secrets: ignore plaintext versions (keep only .sops.yaml files)
*-credentials.yaml
*-oauth*.yaml
!*.sops.yaml
