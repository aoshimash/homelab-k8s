{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],

  // PR limits
  "prConcurrentLimit": 10,
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "automerge": false,

  // Exclude paths
  "ignorePaths": [
    "**/*.sops.yaml",
    ".sops.yaml",
    "k8s/flux/flux-system/gotk-components.yaml"
  ],

  // Flux HelmRelease targets
  "flux": {
    "fileMatch": ["k8s/infrastructure/.+\\.yaml$"]
  },

  // PR labels
  "labels": ["dependencies", "renovate"],

  // Custom managers for Talos / Kubernetes versions in talconfig.yaml
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/infra/talos/talconfig\\.yaml$/"],
      "matchStrings": ["talosVersion:\\s*(?<currentValue>v[\\d.]+)"],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/infra/talos/talconfig\\.yaml$/"],
      "matchStrings": ["kubernetesVersion:\\s*(?<currentValue>v[\\d.]+)"],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases"
    }
  ],

  // Group Talos OS and Kubernetes upgrades into a single PR — both target
  // infra/talos/talconfig.yaml and share the same manual-apply workflow.
  "packageRules": [
    {
      "matchPackageNames": ["siderolabs/talos", "kubernetes/kubernetes"],
      "groupName": "Talos cluster versions",
      "prBodyNotes": [
        "**Manual action required after merge** — this PR does not auto-apply.",
        "After merging, run the relevant tasks locally for whichever versions changed:",
        "- `task talos:upgrade` for the Talos OS version",
        "- `task talos:upgrade-k8s` for the Kubernetes version",
        "See [docs/talos-operations.md — Renovate upgrade flow](https://github.com/aoshimash/homelab-k8s/blob/main/docs/talos-operations.md#renovate-upgrade-flow) for the full procedure and rollback strategy."
      ]
    }
  ]
}
