{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],

  // Friday-evening cadence — keeps weekday CI/build machines free of routine update noise.
  "timezone": "Asia/Tokyo",
  "schedule": ["after 6pm on friday"],

  // PR limits
  "prConcurrentLimit": 10,
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "automerge": false,

  // Stabilization window — a release must be this old before Renovate proposes it,
  // so short-lived broken releases get pulled before we upgrade to them.
  "minimumReleaseAge": "3 days",

  // Vulnerability alerts — requires GitHub's Dependabot alerts enabled on this repo.
  // These values match Renovate's own defaults for vulnerabilityAlerts (schedule/
  // minimumReleaseAge are bypassed already); set explicitly so the intent survives
  // future default changes.
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "minimumReleaseAge": null
  },

  // OSV-based scanning covers crate/go/npm/pypi/etc. datasources — a no-op for this
  // repo's current flux/github-actions/github-releases managers, but harmless and
  // ready if dependency types expand later.
  "osvVulnerabilityAlerts": true,

  // Exclude paths
  "ignorePaths": [
    "**/*.sops.yaml",
    ".sops.yaml",
    "k8s/flux/flux-system/gotk-components.yaml"
  ],

  // Flux HelmRelease targets
  "flux": {
    "fileMatch": ["k8s/infrastructure/.+\\.yaml$"]
  },

  // PR labels
  "labels": ["dependencies", "renovate"],

  // Custom managers for Talos / Kubernetes versions in talconfig.yaml
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/infra/talos/talconfig\\.yaml$/"],
      "matchStrings": ["talosVersion:\\s*(?<currentValue>v[\\d.]+)"],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/infra/talos/talconfig\\.yaml$/"],
      "matchStrings": ["kubernetesVersion:\\s*(?<currentValue>v[\\d.]+)"],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases"
    }
  ],

  "packageRules": [
    // Group Helm chart updates into one PR instead of one per HelmRelease file.
    // separateMajorMinor above still splits major/minor updates into their own
    // PRs even within this group.
    {
      "matchManagers": ["flux"],
      "groupName": "Helm charts"
    },
    // Manual-apply instructions injected into PR bodies. Talos OS and Kubernetes
    // upgrades are kept as separate rules (and therefore separate PRs) because
    // their apply procedures, blast radius, and verification differ.
    {
      "matchPackageNames": ["siderolabs/talos"],
      "prBodyNotes": [
        "**Manual action required after merge** — this PR does not auto-apply.",
        "After merging, follow the Talos OS upgrade procedure in [docs/talos-operations.md — Renovate upgrade flow](https://github.com/aoshimash/homelab-k8s/blob/main/docs/talos-operations.md#renovate-upgrade-flow). The procedure includes the `talosctl upgrade` invocation, health-check gate, and rollback strategy."
      ]
    },
    {
      "matchPackageNames": ["kubernetes/kubernetes"],
      "prBodyNotes": [
        "**Manual action required after merge** — this PR does not auto-apply.",
        "After merging, follow the Kubernetes upgrade procedure in [docs/talos-operations.md — Renovate upgrade flow](https://github.com/aoshimash/homelab-k8s/blob/main/docs/talos-operations.md#renovate-upgrade-flow). The procedure includes the `talosctl upgrade-k8s` invocation and verification."
      ]
    }
  ]
}
